/* ===== 我的页面 ===== */
.page-my {
  min-height: 100vh;
  background: #f7f3ee;
  padding-bottom: 60rpx;
}

/* 用户信息卡片 */
.profile-card {
  background: linear-gradient(135deg, #1a3a3a, #1a7a7a);
  padding: 48rpx 36rpx;
  display: flex;
  align-items: center;
  gap: 28rpx;
}
.profile-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  border: 4rpx solid rgba(255,255,255,0.3);
}
.avatar-text {
  font-size: 40rpx;
  color: #fff;
  font-weight: 700;
}
.profile-info {
  flex: 1;
}
.profile-name {
  font-size: 34rpx;
  font-weight: 700;
  color: #fff;
  display: block;
}
.profile-phone {
  font-size: 26rpx;
  color: rgba(255,255,255,0.7);
  margin-top: 6rpx;
  display: block;
}

/* 区块 */
.section {
  margin: 24rpx 32rpx 0;
}
.section-header {
  margin-bottom: 16rpx;
}
.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #2d2a24;
}

/* 菜单卡片（消息中心入口） */
.menu-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.03);
}
.menu-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
}
.menu-icon {
  font-size: 40rpx;
}
.menu-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #2d2a24;
}
.menu-arrow {
  font-size: 36rpx;
  color: #c0b8ae;
  font-weight: 300;
}

/* 退出登录 */
.logout-section {
  padding: 48rpx 32rpx 0;
}
.logout-btn {
  width: 100%;
  height: 88rpx;
  background: #fff;
  border: 2rpx solid #e0d8ce;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #c0392b;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
}
.logout-btn:active {
  background: #fff5f5;
}

/* 微信通知 */
.subscription-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.03);
}
.subscription-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.subscription-desc {
  font-size: 24rpx;
  color: #6b6058;
  line-height: 1.5;
  flex: 1;
  margin-right: 20rpx;
}
.subscribed-info {
  margin-top: 16rpx;
  font-size: 24rpx;
  color: #1a7a7a;
  line-height: 1.5;
}

.version {
  display: block;
  text-align: center;
  font-size: 22rpx;
  color: #c0b8ae;
  margin-top: 32rpx;
}
