/* 价格区间管理（复用通用管理样式） */
@import '../category/category.wxss';

.modal-row {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
  gap: 12rpx;
}
.flex-1 { flex: 1; }
.mx-20 {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  width: 40rpx;
}
.dash-text {
  font-size: 30rpx;
  color: #8a7e72;
}
.switch-row {
  padding: 12rpx 0;
  margin-bottom: 0;
}
.modal-label {
  font-size: 28rpx;
  color: #2d2a24;
  margin-right: 16rpx;
  white-space: nowrap;
}
.data-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 8rpx;
}
.status-tag {
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 12rpx;
  text-align: center;
  min-width: 64rpx;
}
.status-tag.active { background: #e0ecec; color: #1a7a7a; }
.status-tag.disabled { background: #f0ece6; color: #b0a69b; }
