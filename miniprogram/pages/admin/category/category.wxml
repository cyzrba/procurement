<view class="admin-page">
  <!-- 新增按钮 -->
  <view class="admin-toolbar">
    <button class="btn-sm" bindtap="showCreate">+ 新增类目</button>
  </view>

  <!-- 列表 -->
  <view class="empty-state" wx:if="{{list.length === 0}}">
    <text class="empty-icon">📂</text>
    <text class="empty-text">暂无类目，点击上方按钮添加</text>
  </view>

  <view class="data-list">
    <view class="data-item" wx:for="{{list}}" wx:key="_id">
      <view class="data-main">
        <text class="data-name">{{item.name}}</text>
        <text class="data-desc" wx:if="{{item.description}}">{{item.description}}</text>
        <text class="category-attach-badge" wx:if="{{item.media && item.media.length > 0}}">📎 {{item.media.length}}个附件</text>
      </view>
      <view class="data-actions">
        <text class="action-edit" bindtap="showEdit" data-item="{{item}}">编辑</text>
        <text class="action-del" bindtap="handleDelete" data-id="{{item._id}}">删除</text>
      </view>
    </view>
  </view>

  <!-- 弹窗 -->
  <view class="modal-mask" wx:if="{{showModal}}" bindtap="closeModal"></view>
  <view class="modal" wx:if="{{showModal}}">
    <view class="modal-title">{{editing ? '编辑类目' : '新增类目'}}</view>

    <view class="modal-body">
      <input class="modal-input" placeholder="类目名称" model:value="{{formName}}" />
      <textarea class="modal-textarea" placeholder="类目简介（可选）" model:value="{{formDesc}}" />

      <view class="step-upload-btn" bindtap="chooseAttachment">
        <text class="upload-icon">📎</text>
        <text>上传附件</text>
      </view>

      <view class="step-media-list" wx:if="{{_mediaDisplay && _mediaDisplay.length > 0}}">
        <view class="media-item" wx:for="{{_mediaDisplay}}" wx:for-item="m" wx:for-index="midx" wx:key="fileId">
          <text class="media-icon-file">{{getFileIcon(m.name)}}</text>
          <view class="media-info">
            <text class="media-name">{{m.name}}</text>
            <text class="media-size">{{formatSize(m.size)}}</text>
          </view>
          <text class="media-remove" bindtap="removeMedia" data-midx="{{midx}}">✕</text>
        </view>
      </view>
    </view>

    <view class="modal-actions">
      <button class="btn-cancel" bindtap="closeModal">取消</button>
      <button class="btn-confirm" bindtap="handleSave">保存</button>
    </view>
  </view>
</view>