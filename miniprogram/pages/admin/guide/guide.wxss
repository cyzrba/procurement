/* 指南管理 */
@import '../category/category.wxss';

.filter-bar {
  padding: 0 32rpx 16rpx;
}
.filter-picker {
  background: #fff;
  border-radius: 12rpx;
  padding: 16rpx 24rpx;
  font-size: 26rpx;
  color: #2d2a24;
  display: inline-block;
}

.guide-item {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.03);
}
.guide-main {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 12rpx;
}
.guide-name {
  font-size: 26rpx;
  font-weight: 600;
  color: #2d2a24;
  flex: 1;
  line-height: 1.4;
}
.guide-tags {
  flex-shrink: 0;
  margin-left: 12rpx;
}
.badge {
  font-size: 20rpx;
  padding: 4rpx 14rpx;
  border-radius: 10rpx;
}
.badge-draft { background: #f5ede0; color: #c17a3a; }
.badge-published { background: #e0ecec; color: #1a7a7a; }
.badge-unpublished { background: #f0ece6; color: #8a7e72; }

.guide-actions {
  display: flex;
  gap: 20rpx;
  font-size: 24rpx;
}
.action-pub { color: #1a7a7a; }
.action-warn { color: #c17a3a; }

/* ========== 弹窗扩展 ========== */
.form-section {
  margin-bottom: 24rpx;
}

.form-label {
  font-size: 24rpx;
  color: #8a7e72;
  margin-bottom: 12rpx;
}

/* 上传区域 */
.upload-area {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  align-items: flex-start;
}

.upload-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  background: #f5f0eb;
  border: 1rpx dashed #c4b8a8;
  border-radius: 12rpx;
  padding: 20rpx 32rpx;
  min-width: 240rpx;
  cursor: pointer;
}
.upload-btn:active {
  background: #ece3da;
}

.upload-icon {
  font-size: 32rpx;
}

.upload-text {
  font-size: 24rpx;
  color: #6b5e4a;
}

/* 封面预览 */
.cover-preview {
  position: relative;
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  overflow: hidden;
  border: 1rpx solid #e0d5c8;
}

.cover-img {
  width: 100%;
  height: 100%;
}

.cover-remove {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  width: 36rpx;
  height: 36rpx;
  background: rgba(0,0,0,0.5);
  color: #fff;
  border-radius: 50%;
  text-align: center;
  line-height: 36rpx;
  font-size: 22rpx;
}

/* 隐藏的 fileId 输入框（仅用于存值） */
.hidden-input {
  display: none;
}

/* 附件列表 */
.attach-list {
  margin-top: 12rpx;
}

.attach-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #f9f6f2;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  margin-bottom: 8rpx;
}

.attach-info {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex: 1;
  min-width: 0;
}

.attach-icon {
  font-size: 32rpx;
  flex-shrink: 0;
}

.attach-detail {
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.attach-name {
  font-size: 24rpx;
  color: #2d2a24;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.attach-size {
  font-size: 20rpx;
  color: #a89a88;
  margin-top: 2rpx;
}

.attach-remove {
  flex-shrink: 0;
  width: 36rpx;
  height: 36rpx;
  background: #f0e6dc;
  color: #c17a3a;
  border-radius: 50%;
  text-align: center;
  line-height: 36rpx;
  font-size: 22rpx;
  margin-left: 12rpx;
}
.attach-remove:active {
  background: #e3d5c4;
}

/* 长的多行输入框 */
.modal-textarea.tall {
  height: 240rpx;
}
