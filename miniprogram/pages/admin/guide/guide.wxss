/* 指南管理 */
@import '../category/category.wxss';

.filter-bar {
  padding: 0 32rpx 16rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}
.filter-picker {
  background: #fff;
  border-radius: 12rpx;
  padding: 16rpx 24rpx;
  font-size: 26rpx;
  color: #2d2a24;
  display: inline-block;
}

.guide-item {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.03);
}
.guide-main {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 12rpx;
}
.guide-name {
  font-size: 26rpx;
  font-weight: 600;
  color: #2d2a24;
  flex: 1;
  line-height: 1.4;
}
.guide-tags {
  flex-shrink: 0;
  margin-left: 12rpx;
}
.badge {
  font-size: 20rpx;
  padding: 4rpx 14rpx;
  border-radius: 10rpx;
}
.badge-draft { background: #f5ede0; color: #c17a3a; }
.badge-published { background: #e0ecec; color: #1a7a7a; }
.badge-unpublished { background: #f0ece6; color: #8a7e72; }

.guide-actions {
  display: flex;
  gap: 20rpx;
  font-size: 24rpx;
}
.action-edit { font-size: 24rpx; color: #1a7a7a; padding: 8rpx; }
.action-preview { font-size: 24rpx; color: #2c8c3a; padding: 8rpx; }
.action-pub { color: #1a7a7a; padding: 8rpx; }
.action-warn { color: #c17a3a; padding: 8rpx; }

/* ========== 弹窗扩展 ========== */
.form-section {
  margin-bottom: 24rpx;
}

/* ===== 分区标题 ===== */
.section-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #1a3a3a;
  margin-bottom: 16rpx;
  padding-left: 4rpx;
}

/* ===== 前期准备 ===== */
.prep-textarea {
  width: 100%;
  background: #f5f2ed;
  border-radius: 14rpx;
  padding: 28rpx 32rpx;
  font-size: 28rpx;
  color: #2d2a24;
  height: 300rpx;
  box-sizing: border-box;
  text-align: left;
}

/* ===== 采购流程步骤卡片 ===== */
.step-card {
  background: #faf9f6;
  border: 1rpx solid #e8e2d8;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.step-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.step-header-right {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.step-badge {
  font-size: 24rpx;
  font-weight: 700;
  color: #1a7a7a;
  background: #e0ecec;
  border-radius: 8rpx;
  padding: 6rpx 20rpx;
}

/* ===== 分组开关 ===== */
.group-toggle {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  background: #f0ece6;
  font-size: 22rpx;
}

.group-toggle.on {
  background: #e0ecec;
  color: #1a7a7a;
}

.toggle-switch {
  font-size: 24rpx;
}

.toggle-label {
  font-size: 22rpx;
  color: #6b5e4a;
}

.group-toggle.on .toggle-label {
  color: #1a7a7a;
  font-weight: 600;
}

.step-del {
  font-size: 22rpx;
  color: #c0392b;
  padding: 8rpx 16rpx;
  background: #fde8e8;
  border-radius: 8rpx;
}

.step-del:active {
  background: #f5c6c6;
}

.step-textarea {
  width: 100%;
  background: #fff;
  border: 1rpx solid #e0d5c8;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  font-size: 26rpx;
  color: #2d2a24;
  height: 160rpx;
  box-sizing: border-box;
  text-align: left;
  margin-bottom: 16rpx;
}

/* ===== 上传按钮 ===== */
.step-upload-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  background: #f0ece6;
  border: 1rpx dashed #c4b8a8;
  border-radius: 12rpx;
  padding: 18rpx 24rpx;
  margin-bottom: 12rpx;
  font-size: 24rpx;
  color: #6b5e4a;
}

.step-upload-btn:active {
  background: #e3d5c4;
}

.upload-icon {
  font-size: 28rpx;
}

/* ===== 媒体列表 ===== */
.step-media-list {
  margin-top: 4rpx;
}

.media-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
  background: #fff;
  border-radius: 10rpx;
  padding: 14rpx 16rpx;
  margin-bottom: 8rpx;
  border: 1rpx solid #ece7df;
}

.media-thumb {
  width: 72rpx;
  height: 72rpx;
  border-radius: 8rpx;
  flex-shrink: 0;
  background: #f0ece6;
}

.media-icon-video,
.media-icon-file {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  border-radius: 8rpx;
  flex-shrink: 0;
  background: #f0ece6;
}

.media-info {
  flex: 1;
  min-width: 0;
}

.media-name {
  font-size: 24rpx;
  color: #2d2a24;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.media-size {
  font-size: 20rpx;
  color: #a89a88;
  margin-top: 2rpx;
  display: block;
}

.media-remove {
  flex-shrink: 0;
  width: 36rpx;
  height: 36rpx;
  background: #f0e6dc;
  color: #c17a3a;
  border-radius: 50%;
  text-align: center;
  line-height: 36rpx;
  font-size: 22rpx;
}

.media-remove:active {
  background: #e3d5c4;
}

/* ===== 分组列表 ===== */
.group-list {
  margin-bottom: 12rpx;
}

.group-card {
  background: #fff;
  border: 1rpx solid #e8e2d8;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  margin-bottom: 12rpx;
}

.group-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.group-label {
  font-size: 22rpx;
  font-weight: 700;
  color: #1a7a7a;
  background: #e0ecec;
  border-radius: 6rpx;
  padding: 4rpx 16rpx;
  flex: 1;
}

.group-textarea {
  width: 100%;
  height: 160rpx;
  background: #f5f2ed;
  border-radius: 10rpx;
  padding: 16rpx 20rpx;
  font-size: 26rpx;
  color: #2d2a24;
  box-sizing: border-box;
  text-align: left;
  margin-bottom: 12rpx;
}

.group-del {
  flex-shrink: 0;
  width: 44rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #fde8e8;
  color: #c0392b;
  border-radius: 50%;
  font-size: 22rpx;
}

.group-del:active {
  background: #f5c6c6;
}

/* ===== 新增步骤/子项 ===== */
.add-step-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  background: transparent;
  border: 2rpx dashed #1a7a7a;
  border-radius: 14rpx;
  padding: 22rpx;
  font-size: 26rpx;
  color: #1a7a7a;
  margin-top: 4rpx;
}

.add-step-btn:active {
  background: #e0ecec;
}
