<view class="admin-page">
  <view class="admin-toolbar">
    <button class="btn-sm" bindtap="showCreate">+ 新建指南</button>
  </view>

  <!-- 筛选 -->
  <view class="filter-bar">
    <picker class="filter-picker" mode="selector" range="{{statusOptions}}" value="{{statusIdx}}" bindchange="filterByStatus">
      <text>{{statusOptions[statusIdx]}}</text>
    </picker>
  </view>

  <view class="data-list">
    <view class="guide-item" wx:for="{{list}}" wx:key="_id">
      <view class="guide-main">
        <text class="guide-name">{{item.title}}</text>
        <view class="guide-tags">
          <text class="badge badge-{{item.status}}">{{statusMap[item.status]}}</text>
        </view>
      </view>
      <view class="guide-actions">
        <text class="action-edit" bindtap="editGuide" data-id="{{item._id}}">编辑</text>
        <text class="action-{{item.status === 'published' ? 'warn' : 'pub'}}"
              wx:if="{{item.status === 'draft' || item.status === 'unpublished'}}"
              bindtap="publishGuide" data-id="{{item._id}}">发布</text>
        <text class="action-warn" wx:elif="{{item.status === 'published'}}"
              bindtap="unpublishGuide" data-id="{{item._id}}">下架</text>
        <text class="action-del" bindtap="deleteGuide" data-id="{{item._id}}">删除</text>
      </view>
    </view>
  </view>

  <!-- 新建/编辑弹窗 -->
  <view class="modal-mask" wx:if="{{showModal}}" bindtap="closeModal"></view>
  <view class="modal" wx:if="{{showModal}}" catchtap="noop">
    <view class="modal-title">{{editingId ? '编辑指南' : '新建指南'}}</view>

    <view class="modal-body">
        <!-- 标题 -->
        <input class="modal-input" placeholder="指南标题" model:value="{{formTitle}}" />

        <!-- 类目选择 -->
        <picker class="modal-picker" mode="selector"
                range="{{categoryOptions}}" value="{{formCategoryIdx}}" bindchange="pickCategory">
          <text>{{formCategoryIdx > 0 ? categoryOptions[formCategoryIdx] : '-- 请选择类目 --'}}</text>
        </picker>

        <!-- 价格区间选择 -->
        <picker class="modal-picker" mode="selector"
                range="{{priceRangeOptions}}" value="{{formPriceIdx}}" bindchange="pickPriceRange">
          <text>{{formPriceIdx > 0 ? priceRangeOptions[formPriceIdx] : '-- 请选择价格区间 --'}}</text>
        </picker>

        <!-- 封面图 -->
        <view class="form-section">
          <view class="form-label">封面图</view>
          <view class="upload-area">
            <view class="upload-btn" bindtap="chooseCoverImage">
              <text wx:if="{{!uploadLoading}}" class="upload-icon">📷</text>
              <text wx:if="{{!uploadLoading}}" class="upload-text">选择封面图</text>
              <text wx:if="{{uploadLoading}}" class="upload-text">上传中…</text>
            </view>
            <view class="cover-preview" wx:if="{{formCoverPreview || formCover}}">
              <image class="cover-img" src="{{formCoverPreview || formCover}}" mode="aspectFill"
                     wx:if="{{formCoverPreview || formCover}}" />
              <text class="cover-remove" bindtap="removeCover">✕</text>
            </view>
          </view>
          <!-- 保留隐藏的 fileId 输入用于编辑回显 -->
          <input class="modal-input hidden-input" placeholder="封面图 fileId" model:value="{{formCover}}" />
        </view>

        <!-- 正文内容 -->
        <view class="form-section">
          <view class="form-label">正文内容（HTML格式）</view>
          <textarea class="modal-textarea tall" placeholder="正文内容（HTML格式）" model:value="{{formContent}}" />
        </view>

        <!-- 附件 -->
        <view class="form-section">
          <view class="form-label">附件</view>
          <view class="upload-btn" bindtap="chooseAttachment">
            <text class="upload-icon">📎</text>
            <text class="upload-text">{{uploadLoading ? '上传中…' : '添加附件（PDF/Word/Excel）'}}</text>
          </view>

          <!-- 附件列表 -->
          <view class="attach-list" wx:if="{{formAttachmentList.length > 0}}">
            <view class="attach-item" wx:for="{{formAttachmentList}}" wx:for-index="idx" wx:key="fileId">
              <view class="attach-info">
                <text class="attach-icon">{{item.icon}}</text>
                <view class="attach-detail">
                  <text class="attach-name">{{item.name}}</text>
                  <text class="attach-size">{{item.sizeDisplay}}</text>
                </view>
              </view>
              <text class="attach-remove" data-index="{{idx}}" bindtap="removeAttachment">✕</text>
            </view>
          </view>
        </view>
      </view>

      <view class="modal-actions">
        <button class="btn-cancel" bindtap="closeModal">取消</button>
        <button class="btn-confirm" bindtap="saveDraft">存草稿</button>
      </view>
    </view>
</view>
