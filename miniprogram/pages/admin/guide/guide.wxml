<view class="admin-page">
  <view class="admin-toolbar">
    <button class="btn-sm" bindtap="showCreate">+ 新建指南</button>
  </view>

  <!-- 筛选 -->
  <view class="filter-bar">
    <picker class="filter-picker" mode="selector" range="{{statusOptions}}" value="{{statusIdx}}" bindchange="filterByStatus">
      <text>{{statusOptions[statusIdx]}}</text>
    </picker>
    <picker class="filter-picker" mode="selector" range="{{filterCategoryOptions}}" value="{{filterCategoryIdx}}" bindchange="filterByCategory">
      <text>{{filterCategoryOptions[filterCategoryIdx]}}</text>
    </picker>
  </view>

  <view class="data-list">
    <view class="guide-item" wx:for="{{list}}" wx:key="_id">
      <view class="guide-main">
        <text class="guide-name">{{item.categoryName ? item.categoryName + ' - ' : ''}}{{item.title}}</text>
        <view class="guide-tags">
          <text class="badge badge-{{item.status}}">{{statusMap[item.status]}}</text>
        </view>
      </view>
      <view class="guide-actions">
        <text class="action-preview" bindtap="previewGuide" data-id="{{item._id}}">预览</text>
        <text class="action-edit" bindtap="editGuide" data-id="{{item._id}}">编辑</text>
        <text class="action-{{item.status === 'published' ? 'warn' : 'pub'}}"
              wx:if="{{item.status === 'draft' || item.status === 'unpublished'}}"
              bindtap="publishGuide" data-id="{{item._id}}">发布</text>
        <text class="action-warn" wx:elif="{{item.status === 'published'}}"
              bindtap="unpublishGuide" data-id="{{item._id}}">下架</text>
        <text class="action-del" bindtap="deleteGuide" data-id="{{item._id}}">删除</text>
      </view>
    </view>

    <view class="empty-state" wx:if="{{list.length === 0}}">
      <text class="empty-icon">📄</text>
      <text class="empty-text">暂无内容</text>
    </view>
  </view>

  <!-- 新建/编辑弹窗 -->
  <view class="modal-mask" wx:if="{{showModal}}" bindtap="closeModal"></view>
  <view class="modal" wx:if="{{showModal}}" catchtap="noop">
    <view class="modal-title">{{editingId ? '编辑指南' : '新建指南'}}</view>

    <view class="modal-body">
        <input class="modal-input" placeholder="指南标题" model:value="{{formTitle}}" />

        <picker class="modal-picker" mode="selector"
                range="{{categoryOptions}}" value="{{formCategoryIdx}}" bindchange="pickCategory">
          <text>{{formCategoryIdx > 0 ? categoryOptions[formCategoryIdx] : '-- 请选择类目 --'}}</text>
        </picker>

        <picker class="modal-picker" mode="selector"
                range="{{priceRangeOptions}}" value="{{formPriceIdx}}" bindchange="pickPriceRange">
          <text>{{formPriceIdx > 0 ? priceRangeOptions[formPriceIdx] : '-- 请选择价格区间 --'}}</text>
        </picker>

        <view class="form-section">
          <view class="section-title">前期准备</view>
          <textarea class="prep-textarea" placeholder="请输入前期准备内容..." model:value="{{formPreparationContent}}" maxlength="500" />
          <view class="step-upload-btn" bindtap="choosePreparationMedia">
            <text class="upload-icon">📎</text>
            <text>上传附件/图片/视频</text>
          </view>
          <view class="step-media-list" wx:if="{{_preparationMediaDisplay && _preparationMediaDisplay.length > 0}}">
            <view class="media-item" wx:for="{{_preparationMediaDisplay}}" wx:for-item="m" wx:for-index="midx" wx:key="fileId">
              <image wx:if="{{m.type === 'image'}}" class="media-thumb" src="{{m.fileId}}" mode="aspectFill" />
              <text wx:elif="{{m.type === 'video'}}" class="media-icon-video">🎬</text>
              <text wx:else class="media-icon-file">{{getFileIcon(m.name)}}</text>
              <view class="media-info">
                <text class="media-name">{{m.name}}</text>
                <text class="media-size">{{formatSize(m.size)}}</text>
              </view>
              <text class="media-remove" bindtap="removePreparationMedia" data-midx="{{midx}}">✕</text>
            </view>
          </view>
        </view>

        <view class="form-section">
          <view class="section-title">采购流程</view>

          <view class="step-card" wx:for="{{formSteps}}" wx:for-index="stepIdx" wx:key="_key">
            <view class="step-header">
              <text class="step-badge">步骤 {{stepIdx + 1}}</text>
              <view class="step-header-right">
                <view class="group-toggle {{item.hasGroups ? 'on' : ''}}" bindtap="toggleGroupMode" data-index="{{stepIdx}}">
                  <text class="toggle-switch">{{item.hasGroups ? '☑' : '☐'}}</text>
                  <text class="toggle-label">分组</text>
                </view>
                <text class="step-del" wx:if="{{formSteps.length > 1}}" bindtap="removeStep" data-index="{{stepIdx}}">删除</text>
              </view>
            </view>

            <textarea class="step-textarea" placeholder="{{item.hasGroups ? '请输入主标题...' : '请输入该步骤内容...'}}"
              value="{{item.description}}"
              bindinput="onStepDescInput" data-index="{{stepIdx}}" maxlength="500" />

            <!-- 步骤附件（始终显示） -->
            <view class="step-upload-btn" bindtap="chooseStepMedia" data-index="{{stepIdx}}">
              <text class="upload-icon">📎</text>
              <text>上传附件/图片/视频</text>
            </view>

            <view class="step-media-list" wx:if="{{item._mediaDisplay && item._mediaDisplay.length > 0}}">
              <view class="media-item" wx:for="{{item._mediaDisplay}}" wx:for-item="m" wx:for-index="midx" wx:key="fileId">
                <image wx:if="{{m.type === 'image'}}" class="media-thumb" src="{{m.fileId}}" mode="aspectFill" />
                <text wx:elif="{{m.type === 'video'}}" class="media-icon-video">🎬</text>
                <text wx:else class="media-icon-file">{{getFileIcon(m.name)}}</text>
                <view class="media-info">
                  <text class="media-name">{{m.name}}</text>
                  <text class="media-size">{{formatSize(m.size)}}</text>
                </view>
                <text class="media-remove" bindtap="removeStepMedia" data-step="{{stepIdx}}" data-midx="{{midx}}">✕</text>
              </view>
            </view>

            <!-- 有分组：显示子项列表 -->
            <block wx:if="{{item.hasGroups}}">
              <view class="group-list">
                <view class="group-card" wx:for="{{item.groups}}" wx:for-index="groupIdx" wx:key="_key">
                  <view class="group-header">
                    <text class="group-label">子项 {{groupIdx + 1}}</text>
                    <text class="group-del" wx:if="{{item.groups.length > 1}}"
                      bindtap="removeGroup"
                      data-step-idx="{{stepIdx}}"
                      data-group-idx="{{groupIdx}}">✕</text>
                  </view>
                  <textarea class="group-textarea" placeholder="请输入子项内容..."
                    value="{{item.title}}"
                    bindinput="onGroupTitleInput"
                    data-step-idx="{{stepIdx}}"
                    data-group-idx="{{groupIdx}}" maxlength="500" />

                  <view class="step-upload-btn" bindtap="chooseGroupMedia" data-step-idx="{{stepIdx}}" data-group-idx="{{groupIdx}}">
                    <text class="upload-icon">📎</text>
                    <text>上传附件/图片/视频</text>
                  </view>

                  <view class="step-media-list" wx:if="{{item._mediaDisplay && item._mediaDisplay.length > 0}}">
                    <view class="media-item" wx:for="{{item._mediaDisplay}}" wx:for-item="m" wx:for-index="midx" wx:key="fileId">
                      <image wx:if="{{m.type === 'image'}}" class="media-thumb" src="{{m.fileId}}" mode="aspectFill" />
                      <text wx:elif="{{m.type === 'video'}}" class="media-icon-video">🎬</text>
                      <text wx:else class="media-icon-file">{{getFileIcon(m.name)}}</text>
                      <view class="media-info">
                        <text class="media-name">{{m.name}}</text>
                        <text class="media-size">{{formatSize(m.size)}}</text>
                      </view>
                      <text class="media-remove" bindtap="removeGroupMedia"
                        data-step-idx="{{stepIdx}}" data-group-idx="{{groupIdx}}" data-midx="{{midx}}">✕</text>
                    </view>
                  </view>
                </view>
              </view>

              <view class="add-step-btn" bindtap="addGroup" data-step-idx="{{stepIdx}}">
                <text>+ 新增子项</text>
              </view>
            </block>
          </view>

          <view class="add-step-btn" bindtap="addStep">
            <text>+ 新增步骤</text>
          </view>
        </view>
      </view>

      <view class="modal-actions">
        <button class="btn-cancel" bindtap="closeModal">取消</button>
        <button class="btn-confirm" bindtap="saveDraft">存草稿</button>
      </view>
    </view>
</view>
