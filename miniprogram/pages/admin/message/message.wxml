<view class="admin-page">
  <!-- 新建消息 -->
  <view class="admin-toolbar">
    <button class="btn-sm" bindtap="showCreate">+ 新建消息</button>
  </view>

  <view class="data-list">
    <view class="data-item" wx:for="{{list}}" wx:key="_id">
      <view class="data-main">
        <text class="data-name">{{item.title}}</text>
        <text class="data-desc">{{item.content}}</text>
        <text class="data-time">{{formatTime(item.createdAt)}}</text>
      </view>
      <view class="data-actions">
        <view class="data-tag">
          <text class="tag-{{item.type}}">{{item.type === 'announcement' ? '公告' : '更新'}}</text>
        </view>
        <button class="btn-subscription-sm" data-id="{{item._id}}" bindtap="handleSendSubscription" disabled="{{sendingSubscription}}" size="mini">订阅推送</button>
      </view>
    </view>
  </view>

  <!-- 新建弹窗 -->
  <view class="modal-mask" wx:if="{{showModal}}" bindtap="closeModal"></view>
  <view class="modal" wx:if="{{showModal}}">
    <view class="modal-title">新建消息通知</view>
    <view class="modal-body">
      <input class="modal-input" placeholder="消息标题" model:value="{{formTitle}}" />
      <textarea class="modal-textarea" placeholder="消息内容" model:value="{{formContent}}" />

      <view class="modal-section-label">类型</view>
      <picker class="modal-picker" mode="selector" range="{{['公告', '更新']}}" value="{{formTypeIdx}}" bindchange="pickType">
        <text>{{['公告', '更新'][formTypeIdx]}}</text>
      </picker>

      <view class="modal-section-label">发送范围</view>
      <picker class="modal-picker" mode="selector" range="{{['全部用户', '指定用户']}}" value="{{formTargetIdx}}" bindchange="pickTarget">
        <text>{{['全部用户', '指定用户'][formTargetIdx]}}</text>
      </picker>
    </view>
    <view class="modal-actions">
      <button class="btn-cancel" bindtap="closeModal">取消</button>
      <button class="btn-confirm" bindtap="handleSend">发送</button>
    </view>
  </view>
</view>
