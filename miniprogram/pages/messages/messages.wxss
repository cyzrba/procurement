/* ===== 消息通知页面 ===== */
.page-messages {
  min-height: 100vh;
  background: #f7f3ee;
  padding: 24rpx 32rpx 60rpx;
}

/* 消息列表 */
.msg-item {
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx 24rpx;
  margin-bottom: 16rpx;
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.03);
}
.msg-indicator {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  margin-top: 10rpx;
  flex-shrink: 0;
}
.msg-indicator.announce { background: #c17a3a; }
.msg-indicator.update { background: #1a7a7a; }
.msg-body { flex: 1; }
.msg-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #2d2a24;
  display: block;
}
.msg-content-text {
  font-size: 24rpx;
  color: #6b6058;
  margin-top: 8rpx;
  display: block;
  line-height: 1.4;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}
.msg-time {
  font-size: 20rpx;
  color: #b0a69b;
  margin-top: 10rpx;
  display: block;
}
.msg-type-tag {
  flex-shrink: 0;
}
.msg-type-tag text {
  font-size: 22rpx;
  padding: 4rpx 14rpx;
  border-radius: 10rpx;
  white-space: nowrap;
}
.tag-announcement {
  background: #f5ede0;
  color: #c17a3a;
}
.tag-guide_update {
  background: #e0ecec;
  color: #1a7a7a;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}
.empty-icon { font-size: 64rpx; }
.empty-text {
  font-size: 26rpx;
  color: #b0a69b;
  margin-top: 12rpx;
}

/* 加载更多 */
.load-more {
  text-align: center;
  padding: 16rpx 0 32rpx;
}
.load-more-text {
  font-size: 24rpx;
  color: #1a7a7a;
}
