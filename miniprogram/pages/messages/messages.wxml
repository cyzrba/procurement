<view class="page-messages">
  <view class="empty-state" wx:if="{{list.length === 0 && !loading}}">
    <text class="empty-icon">🔔</text>
    <text class="empty-text">暂无消息</text>
  </view>

  <view class="msg-list">
    <view class="msg-item" wx:for="{{list}}" wx:key="_id">
      <view class="msg-indicator {{item.type === 'announcement' ? 'announce' : 'update'}}"></view>
      <view class="msg-body">
        <text class="msg-title">{{item.title}}</text>
        <text class="msg-content-text">{{item.content}}</text>
        <text class="msg-time">{{formatTime(item.createdAt)}}</text>
      </view>
      <view class="msg-type-tag">
        <text class="tag-{{item.type}}">{{item.type === 'announcement' ? '公告' : '更新'}}</text>
      </view>
    </view>
  </view>

  <view class="load-more" wx:if="{{hasMore}}">
    <text class="load-more-text" bindtap="loadMore">加载更多</text>
  </view>
</view>
