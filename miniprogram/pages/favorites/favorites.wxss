.page-favorites {
  min-height: 100vh;
  background: #f7f3ee;
  padding: 32rpx;
}

.list-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}
.list-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #2d2a24;
}
.list-count {
  font-size: 24rpx;
  color: #8a7e72;
}

.category-tabs {
  white-space: nowrap;
  margin-bottom: 24rpx;
  padding-bottom: 8rpx;
}
.category-tab {
  display: inline-block;
  padding: 14rpx 28rpx;
  margin-right: 16rpx;
  border-radius: 32rpx;
  background: #fff;
  font-size: 26rpx;
  color: #6b6058;
  white-space: nowrap;
  transition: all 0.2s;
  box-shadow: 0 2rpx 6rpx rgba(0,0,0,0.04);
}
.category-tab.active {
  background: #1a7a7a;
  color: #fff;
  font-weight: 600;
}
.category-tab-text {
  display: inline;
}

.guide-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.guide-card {
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
  display: flex;
  align-items: center;
}
.guide-main {
  flex: 1;
  min-width: 0;
}
.guide-card .guide-info {
  padding: 24rpx 28rpx 28rpx;
}
.guide-card .guide-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #2d2a24;
  display: block;
  line-height: 1.4;
}
.guide-card .guide-date {
  font-size: 22rpx;
  color: #b0a69b;
  margin-top: 8rpx;
  display: block;
}

.fav-star {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-right: 8rpx;
}
.star-icon {
  font-size: 48rpx;
  color: #e8a838;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}
.empty-icon { font-size: 80rpx; color: #d0ccc6; }
.empty-text {
  font-size: 30rpx;
  color: #8a7e72;
  margin-top: 16rpx;
}
.empty-hint {
  font-size: 24rpx;
  color: #b0a69b;
  margin-top: 8rpx;
}
