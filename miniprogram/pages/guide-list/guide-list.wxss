/* ===== 指南列表 ===== */
.page-guide-list {
  min-height: 100vh;
  background: #f7f3ee;
  padding-bottom: 40rpx;
}

.price-banner {
  background: linear-gradient(135deg, #1a7a7a, #145c5c);
  padding: 36rpx 40rpx;
  color: #fff;
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.price-label {
  font-size: 24rpx;
  opacity: 0.8;
}
.price-value {
  font-size: 36rpx;
  font-weight: 700;
  display: block;
  margin-top: 8rpx;
}
.price-range {
  font-size: 26rpx;
  opacity: 0.7;
  margin-top: 6rpx;
  display: block;
}

.price-banner-right {
  flex-shrink: 0;
  margin-left: 24rpx;
  text-align: right;
}

.category-name {
  font-size: 40rpx;
  font-weight: 700;
  color: #fff;
  display: block;
  text-shadow: 0 2rpx 8rpx rgba(0,0,0,0.2);
}

.list-section {
  padding: 32rpx 32rpx 0;
}
.list-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}
.list-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #2d2a24;
}
.list-count {
  font-size: 24rpx;
  color: #8a7e72;
}

.guide-card {
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
  display: flex;
  align-items: center;
}
.guide-main {
  flex: 1;
  min-width: 0;
}
.guide-main:active {
  opacity: 0.7;
}
.fav-star {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-right: 8rpx;
}
.fav-star:active {
  transform: scale(1.2);
  transition: transform 0.15s;
}
.star-icon {
  font-size: 48rpx;
  color: #d0ccc6;
  transition: color 0.2s;
}
.fav-star.active .star-icon {
  color: #e8a838;
}
.guide-info {
  padding: 24rpx 28rpx 28rpx;
}
.guide-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #2d2a24;
  display: block;
  line-height: 1.4;
}
.guide-date {
  font-size: 22rpx;
  color: #b0a69b;
  margin-top: 8rpx;
  display: block;
}
.guide-tags {
  display: flex;
  gap: 12rpx;
  margin-top: 12rpx;
}
.tag {
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}
.tag-price {
  background: #f0f7f7;
  color: #1a7a7a;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0;
}
.empty-icon { font-size: 72rpx; }
.empty-text {
  font-size: 28rpx;
  color: #b0a69b;
  margin-top: 16rpx;
}

.re-query {
  text-align: center;
  font-size: 26rpx;
  color: #8a7e72;
  padding: 24rpx;
}
