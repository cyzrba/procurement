<view class="page-home">
  <!-- 顶部欢迎 -->
  <view class="welcome-bar">
    <view class="welcome-left">
      <text class="welcome-greeting">您好, {{userName}}</text>
      <text class="welcome-hint">请选择采购类目</text>
    </view>
    <view class="welcome-avatar">
      <text class="avatar-text">{{initial}}</text>
    </view>
  </view>

  <!-- 步骤指示器 -->
  <view class="steps">
    <view class="step active">
      <view class="step-circle">1</view>
      <text class="step-label">选择类目</text>
    </view>
    <view class="step-line"></view>
    <view class="step">
      <view class="step-circle">2</view>
      <text class="step-label">选择预算</text>
    </view>
    <view class="step-line"></view>
    <view class="step">
      <view class="step-circle">3</view>
      <text class="step-label">获取指南</text>
    </view>
  </view>

  <!-- 选择类目 -->
  <view class="section">
    <view class="section-title">选择采购类目</view>
    <view class="category-list">
      <view class="category-item" wx:for="{{categories}}" wx:key="_id" bindtap="selectCategory" data-id="{{item._id}}" data-name="{{item.name}}">
        <view class="category-top">
          <view class="category-left">
            <text class="category-name">{{item.name}}</text>
          </view>
        </view>
        <view class="category-desc-wrap">
          <text class="category-desc">{{item.description || '暂无简介'}}</text>
        </view>
        <view class="category-doc-list" wx:if="{{item._documents && item._documents.length > 0}}">
          <view class="doc-item" wx:for="{{item._documents}}" wx:for-item="doc" wx:key="fileId"
            catchtap="openDocMenu" data-fileid="{{doc.fileId}}" data-name="{{doc.name}}">
            <text class="doc-icon">{{getFileIcon(doc.name)}}</text>
            <view class="doc-info">
              <text class="doc-name">{{doc.name}}</text>
              <text class="doc-size">{{formatSize(doc.size)}}</text>
            </view>
          </view>
        </view>
      </view>
    </view>
    <view class="empty-state" wx:if="{{categories.length === 0}}">
      <text class="empty-icon">📭</text>
      <text class="empty-text">暂无可选类目</text>
    </view>
  </view>
</view>