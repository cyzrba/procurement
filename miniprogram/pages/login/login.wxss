/* ===== 登录页 ===== */
.page-login {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40rpx 48rpx;
  background: linear-gradient(135deg, #f7f3ee 0%, #e8e0d6 100%);
  position: relative;
  overflow: hidden;
  box-sizing: border-box;
}

/* 背景装饰 */
.bg-shapes {
  position: absolute;
  inset: 0;
  pointer-events: none;
  overflow: hidden;
}
.shape {
  position: absolute;
  border-radius: 50%;
  opacity: 0.15;
}
.shape-1 {
  width: 600rpx; height: 600rpx;
  background: #1a7a7a;
  top: -200rpx; right: -150rpx;
}
.shape-2 {
  width: 400rpx; height: 400rpx;
  background: #e8a838;
  bottom: -100rpx; left: -100rpx;
}
.shape-3 {
  width: 200rpx; height: 200rpx;
  background: #1a7a7a;
  top: 30%; left: -60rpx;
}
.shape-4 {
  width: 150rpx; height: 150rpx;
  background: #d4a373;
  bottom: 30%; right: -40rpx;
}

/* 头部 */
.login-header {
  text-align: center;
  margin-bottom: 60rpx;
  position: relative;
  z-index: 1;
}
.login-title {
  font-size: 48rpx;
  font-weight: 700;
  color: #1a3a3a;
  letter-spacing: 2rpx;
  display: block;
}
.login-subtitle {
  font-size: 26rpx;
  color: #8a7e72;
  margin-top: 12rpx;
  display: block;
  letter-spacing: 4rpx;
}

/* 登录卡片 */
.login-card {
  width: 100%;
  max-width: 560rpx;
  background: rgba(255,255,255,0.92);
  backdrop-filter: blur(20rpx);
  border-radius: 32rpx;
  padding: 48rpx 40rpx;
  box-shadow: 0 8rpx 40rpx rgba(0,0,0,0.06);
  position: relative;
  z-index: 1;
  animation: cardIn 0.5s ease-out;
}

@keyframes cardIn {
  from { opacity: 0; transform: translateY(30rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #2d2a24;
  margin-bottom: 36rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
}
.card-icon {
  font-size: 36rpx;
}

.form-group {
  margin-bottom: 24rpx;
}
.form-input {
  width: 100%;
  height: 88rpx;
  background: #f5f2ed;
  border-radius: 16rpx;
  padding: 0 28rpx;
  font-size: 28rpx;
  color: #2d2a24;
  box-sizing: border-box;
  border: 2rpx solid transparent;
  transition: border-color 0.2s;
}
.form-input:focus {
  border-color: #1a7a7a;
  background: #fff;
}

.btn-primary {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #1a7a7a, #145c5c);
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: 600;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 16rpx;
  border: none;
  box-shadow: 0 4rpx 16rpx rgba(26,122,122,0.3);
  transition: all 0.2s;
}
.btn-primary:active {
  transform: scale(0.98);
  opacity: 0.9;
}
.btn-admin {
  background: linear-gradient(135deg, #c17a3a, #a8642e);
  box-shadow: 0 4rpx 16rpx rgba(193,122,58,0.3);
}

.form-footer {
  text-align: center;
  margin-top: 28rpx;
}
.link {
  font-size: 26rpx;
  color: #1a7a7a;
  text-decoration: underline;
  padding: 8rpx;
}

.version {
  font-size: 22rpx;
  color: #b0a69b;
  margin-top: 40rpx;
  position: relative;
  z-index: 1;
}
