/* ===== 指南详情 ===== */
.page-guide-detail {
  min-height: 100vh;
  background: #f7f3ee;
  padding-bottom: 60rpx;
}

.loading {
  display: flex;
  justify-content: center;
  padding: 100rpx 0;
}
.loading-text { color: #b0a69b; font-size: 28rpx; }

.detail-cover-img {
  width: 100%;
  height: 380rpx;
}

.detail-header {
  padding: 32rpx 36rpx 20rpx;
  background: #fff;
}
.detail-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1a3a3a;
  line-height: 1.4;
  display: block;
}
.detail-meta {
  margin-top: 16rpx;
  display: flex;
  gap: 24rpx;
}
.meta-item {
  font-size: 24rpx;
  color: #8a7e72;
}

.detail-content {
  background: #fff;
  margin-top: 16rpx;
  padding: 32rpx 36rpx;
  font-size: 28rpx;
  line-height: 1.8;
  color: #2d2a24;
  overflow-x: hidden;
}

/* 附件 */
.attachments {
  background: #fff;
  margin-top: 16rpx;
  padding: 28rpx 36rpx;
}
.attachment-header {
  font-size: 28rpx;
  font-weight: 600;
  color: #2d2a24;
  margin-bottom: 20rpx;
}
.attachment-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0ece6;
}
.attachment-item:last-child { border-bottom: none; }
.attach-icon { font-size: 36rpx; margin-right: 16rpx; }
.attach-info { flex: 1; }
.attach-name {
  font-size: 26rpx;
  color: #2d2a24;
  display: block;
}
.attach-size {
  font-size: 22rpx;
  color: #b0a69b;
  margin-top: 4rpx;
  display: block;
}
.attach-action {
  font-size: 24rpx;
  color: #1a7a7a;
  padding: 8rpx 20rpx;
  border: 2rpx solid #1a7a7a;
  border-radius: 12rpx;
}
