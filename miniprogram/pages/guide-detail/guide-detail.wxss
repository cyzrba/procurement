/* ===== 指南详情 ===== */
.page-guide-detail {
  min-height: 100vh;
  background: #f7f3ee;
  padding-bottom: 60rpx;
}

.loading {
  display: flex;
  justify-content: center;
  padding: 100rpx 0;
}
.loading-text { color: #b0a69b; font-size: 28rpx; }

/* ===== 标题区 ===== */
.detail-header {
  padding: 32rpx 36rpx 20rpx;
  background: #fff;
}
.detail-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1a3a3a;
  line-height: 1.4;
  display: block;
}
.detail-meta {
  margin-top: 16rpx;
  display: flex;
  gap: 24rpx;
}
.meta-item {
  font-size: 24rpx;
  color: #8a7e72;
}

/* ===== 通用分区 ===== */
.detail-section {
  background: #fff;
  margin-top: 16rpx;
  padding: 28rpx 36rpx 32rpx;
}
.section-label {
  font-size: 28rpx;
  font-weight: 700;
  color: #1a3a3a;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 2rpx solid #f0ece6;
}

/* ===== 前期准备 ===== */
.prep-content {
  font-size: 28rpx;
  line-height: 1.8;
  color: #2d2a24;
  word-break: break-all;
  overflow: hidden;
}

/* ===== 采购流程步骤 ===== */
.process-step {
  display: flex;
  margin-bottom: 32rpx;
}
.process-step:last-child {
  margin-bottom: 0;
}

/* 左侧步骤指示器 */
.step-indicator {
  width: 56rpx;
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.step-dot-wrapper {
  z-index: 1;
}
.step-dot {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #1a7a7a;
  display: flex;
  align-items: center;
  justify-content: center;
}
.step-dot text {
  color: #fff;
  font-size: 24rpx;
  font-weight: 700;
}
.step-line {
  width: 3rpx;
  flex: 1;
  min-height: 40rpx;
  background: #d4cbbb;
  margin-top: 8rpx;
  margin-bottom: 8rpx;
}

/* 右侧步骤内容 */
.step-content {
  flex: 1;
  padding-left: 24rpx;
  padding-top: 8rpx;
  overflow: hidden;
}
.step-desc {
  font-size: 28rpx;
  line-height: 1.7;
  color: #2d2a24;
  display: block;
  word-break: break-all;
  overflow: hidden;
}

/* ===== 分组 ===== */
.detail-groups {
  margin-top: 24rpx;
}

.detail-group {
  background: #faf9f6;
  border: 1rpx solid #e8e2d8;
  border-radius: 14rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 16rpx;
}

.detail-group:last-child {
  margin-bottom: 0;
}

.detail-group-title {
  font-size: 26rpx;
  font-weight: 700;
  color: #1a3a3a;
  display: block;
  margin-bottom: 16rpx;
  padding-bottom: 12rpx;
  border-bottom: 1rpx solid #e8e2d8;
  word-break: break-all;
  overflow: hidden;
}

/* ===== 步骤媒体 ===== */
.step-media {
  margin-top: 20rpx;
}

/* 图片网格 */
.image-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 20rpx;
}
.grid-image {
  width: 210rpx;
  height: 210rpx;
  border-radius: 12rpx;
  background: #f0ece6;
}

/* 视频 */
.video-list {
  margin-bottom: 20rpx;
}
.video-item {
  margin-bottom: 16rpx;
}
.step-video {
  width: 100%;
  border-radius: 12rpx;
  background: #000;
}
.video-name {
  font-size: 22rpx;
  color: #8a7e72;
  margin-top: 8rpx;
  display: block;
}

.video-save-btn {
  font-size: 24rpx;
  color: #1a7a7a;
  display: inline-block;
  margin-top: 12rpx;
  padding: 8rpx 20rpx;
  border: 2rpx solid #1a7a7a;
  border-radius: 12rpx;
}

/* 文档 */
.doc-list {
  margin-top: 8rpx;
}
.doc-item {
  display: flex;
  align-items: center;
  padding: 20rpx 16rpx;
  background: #faf9f6;
  border-radius: 12rpx;
  margin-bottom: 10rpx;
  border: 1rpx solid #ece7df;
  overflow: hidden;
}
.doc-item:active {
  background: #f0ece6;
}
.doc-icon {
  font-size: 36rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}
.doc-info {
  flex: 1;
  min-width: 0;
}
.doc-name {
  font-size: 26rpx;
  color: #2d2a24;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.doc-size {
  font-size: 22rpx;
  color: #b0a69b;
  margin-top: 4rpx;
  display: block;
}

/* ===== 链接指南卡片 ===== */
.linked-guide-card {
  display: flex;
  align-items: center;
  background: #e0ecec;
  border-left: 6rpx solid #1a7a7a;
  border-radius: 10rpx;
  padding: 18rpx 20rpx;
  margin-top: 20rpx;
  margin-bottom: 4rpx;
}

.linked-guide-card:active {
  background: #c8e0db;
}

.linked-guide-icon {
  font-size: 22rpx;
  color: #1a7a7a;
  font-weight: 600;
  flex-shrink: 0;
  margin-right: 12rpx;
}

.linked-guide-info {
  flex: 1;
  min-width: 0;
}

.linked-guide-hint {
  font-size: 22rpx;
  color: #6b8a84;
  display: block;
  margin-bottom: 2rpx;
}

.linked-guide-name {
  font-size: 26rpx;
  font-weight: 600;
  color: #1a3a3a;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.linked-guide-arrow {
  font-size: 28rpx;
  color: #1a7a7a;
  font-weight: 700;
  flex-shrink: 0;
  margin-left: 12rpx;
}