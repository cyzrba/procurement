.page-price-range {
  min-height: 100vh;
  background: #f7f3ee;
  padding-bottom: 40rpx;
}

/* 步骤指示器 */
.steps {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx 40rpx 20rpx;
}
.step {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}
.step-circle {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: #e0d8ce;
  color: #8a7e72;
  font-size: 24rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s;
}
.step.active .step-circle {
  background: #1a7a7a;
  color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(26,122,122,0.3);
}
.step-label {
  font-size: 22rpx;
  color: #b0a69b;
}
.step.active .step-label {
  color: #1a7a7a;
  font-weight: 600;
}
.step-line {
  width: 80rpx;
  height: 4rpx;
  background: #e0d8ce;
  margin: 0 16rpx;
  margin-bottom: 44rpx;
  border-radius: 2rpx;
  transition: background 0.3s;
}
.step-line.active {
  background: #1a7a7a;
}

/* 区块 */
.section {
  padding: 20rpx 32rpx;
  animation: fadeIn 0.35s ease-out;
}
@keyframes fadeIn {
  from { opacity: 0; transform: translateY(16rpx); }
  to { opacity: 1; transform: translateY(0); }
}
.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #2d2a24;
  margin-bottom: 24rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
}
.section-tag {
  font-size: 22rpx;
  font-weight: 400;
  background: #e0ecec;
  color: #1a7a7a;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}

/* 顶部重新选择类目 */
.top-bar {
  padding: 0 0 12rpx;
}
.back-link {
  font-size: 32rpx;
  color: #1a7a7a;
  font-weight: 700;
  display: inline-block;
  padding: 12rpx 16rpx;
  background: rgba(26,122,122,0.06);
  border-radius: 12rpx;
}
.back-link:active {
  opacity: 0.6;
}

/* 价格区间选择 */
.price-range-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}
.price-range-item {
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx 24rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
  border: 2rpx solid transparent;
  transition: all 0.2s;
}
.price-range-item:active {
  transform: scale(0.98);
}
.price-range-item.selected {
  border-color: #1a7a7a;
  background: #f0f7f7;
  box-shadow: 0 4rpx 16rpx rgba(26,122,122,0.12);
}

.radio-circle {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  border: 3rpx solid #d0ccc6;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  transition: all 0.2s;
}
.radio-circle.checked {
  border-color: #1a7a7a;
  background: #1a7a7a;
}
.radio-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: #fff;
}

.price-range-info {
  flex: 1;
}
.price-range-label {
  font-size: 30rpx;
  font-weight: 600;
  color: #2d2a24;
  display: block;
}
.price-range-desc {
  font-size: 24rpx;
  color: #8a7e72;
  margin-top: 6rpx;
  display: block;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
}
.empty-icon { font-size: 72rpx; }
.empty-text {
  font-size: 28rpx;
  color: #b0a69b;
  margin-top: 16rpx;
}
